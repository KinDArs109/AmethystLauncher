<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brand palette (gaming-dark): deep indigo surfaces, violet accent, rose highlight. -->
    <Color x:Key="LauncherBackgroundColor">#0F0F23</Color>
    <Color x:Key="LauncherSurfaceColor">#1E1C35</Color>
    <Color x:Key="LauncherSurfaceMutedColor">#27273B</Color>
    <Color x:Key="LauncherSurfaceHoverColor">#332F4D</Color>
    <Color x:Key="LauncherAccentColor">#7C3AED</Color>
    <Color x:Key="LauncherAccentSoftColor">#A78BFA</Color>
    <Color x:Key="LauncherAccentDeepColor">#5B21B6</Color>
    <Color x:Key="LauncherHighlightColor">#F43F5E</Color>
    <Color x:Key="LauncherForegroundColor">#E2E8F0</Color>
    <Color x:Key="LauncherMutedForegroundColor">#94A3B8</Color>

    <!-- Semantic status colors — referenced by name, never as raw hex in page XAML. -->
    <Color x:Key="LauncherSuccessColor">#22C55E</Color>
    <Color x:Key="LauncherWarningColor">#F59E0B</Color>
    <Color x:Key="LauncherDangerColor">#EF4444</Color>

    <SolidColorBrush x:Key="LauncherBackgroundBrush" Color="{StaticResource LauncherBackgroundColor}" />
    <SolidColorBrush x:Key="LauncherSurfaceBrush" Color="{StaticResource LauncherSurfaceColor}" />
    <SolidColorBrush x:Key="LauncherSurfaceMutedBrush" Color="{StaticResource LauncherSurfaceMutedColor}" />
    <SolidColorBrush x:Key="LauncherSurfaceHoverBrush" Color="{StaticResource LauncherSurfaceHoverColor}" />
    <SolidColorBrush x:Key="LauncherAccentBrush" Color="{StaticResource LauncherAccentColor}" />
    <SolidColorBrush x:Key="LauncherAccentSoftBrush" Color="{StaticResource LauncherAccentSoftColor}" />
    <SolidColorBrush x:Key="LauncherAccentDeepBrush" Color="{StaticResource LauncherAccentDeepColor}" />
    <SolidColorBrush x:Key="LauncherHighlightBrush" Color="{StaticResource LauncherHighlightColor}" />
    <SolidColorBrush x:Key="LauncherForegroundBrush" Color="{StaticResource LauncherForegroundColor}" />
    <SolidColorBrush x:Key="LauncherMutedForegroundBrush" Color="{StaticResource LauncherMutedForegroundColor}" />
    <SolidColorBrush x:Key="LauncherHairlineBrush" Color="#26FFFFFF" />
    <SolidColorBrush x:Key="LauncherGlassBorderBrush" Color="#20FFFFFF" />
    <SolidColorBrush x:Key="LauncherGlassBorderHoverBrush" Color="#3DA78BFA" />

    <SolidColorBrush x:Key="LauncherSuccessBrush" Color="{StaticResource LauncherSuccessColor}" />
    <SolidColorBrush x:Key="LauncherWarningBrush" Color="{StaticResource LauncherWarningColor}" />
    <SolidColorBrush x:Key="LauncherDangerBrush" Color="{StaticResource LauncherDangerColor}" />

    <!-- Glass-card surface: translucent so the page's ambient gradient reads through, per the
         glassmorphism language used across 21st.dev's card/hero components. -->
    <SolidColorBrush x:Key="LauncherGlassSurfaceBrush" Color="#B81E1C35" />
    <SolidColorBrush x:Key="LauncherGlassSurfaceHoverBrush" Color="#CC27273B" />

    <LinearGradientBrush x:Key="LauncherHeroBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2A1B54" Offset="0" />
        <GradientStop Color="#150F2E" Offset="1" />
    </LinearGradientBrush>

    <!-- "Shiny button" gradient — diagonal sweep across the accent hues, for primary CTAs. -->
    <LinearGradientBrush x:Key="LauncherAccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#8B5CF6" Offset="0" />
        <GradientStop Color="{StaticResource LauncherAccentColor}" Offset="0.55" />
        <GradientStop Color="{StaticResource LauncherAccentDeepColor}" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="LauncherAccentGradientHoverBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#A78BFA" Offset="0" />
        <GradientStop Color="#8B5CF6" Offset="0.55" />
        <GradientStop Color="{StaticResource LauncherAccentColor}" Offset="1" />
    </LinearGradientBrush>

    <!-- Soft ambient glow used behind hero sections / active nav indicator. -->
    <RadialGradientBrush x:Key="LauncherGlowBrush" Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
        <GradientStop Color="#337C3AED" Offset="0" />
        <GradientStop Color="#007C3AED" Offset="1" />
    </RadialGradientBrush>

    <!--
        Window-level ambient blobs — large, heavily-blurred colour fields placed in the corners so the
        flat #0F0F23 background reads with depth (21st.dev "aurora / mesh gradient" ambience). Rendered
        as Ellipse fills in MainWindow behind the transparent NavigationView; never interactive.
    -->
    <RadialGradientBrush x:Key="LauncherAmbientVioletBrush" Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
        <GradientStop Color="#4D7C3AED" Offset="0" />
        <GradientStop Color="#007C3AED" Offset="1" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="LauncherAmbientRoseBrush" Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
        <GradientStop Color="#3DF43F5E" Offset="0" />
        <GradientStop Color="#00F43F5E" Offset="1" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="LauncherAmbientBlueBrush" Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
        <GradientStop Color="#3322D3EE" Offset="0" />
        <GradientStop Color="#0022D3EE" Offset="1" />
    </RadialGradientBrush>

    <!-- Corner-radius rhythm — reuse instead of ad-hoc numbers per Border. -->
    <CornerRadius x:Key="LauncherRadiusSm">8</CornerRadius>
    <CornerRadius x:Key="LauncherRadiusMd">12</CornerRadius>
    <CornerRadius x:Key="LauncherRadiusLg">16</CornerRadius>
    <CornerRadius x:Key="LauncherRadiusXl">20</CornerRadius>

    <!--
        Global text-color override: force every TextBlock/TextBox/ComboBox/label onto the light
        foreground regardless of container, so nothing can default back to black-on-dark.
    -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource LauncherForegroundBrush}" />
    </Style>
    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Foreground" Value="{StaticResource LauncherForegroundBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource LauncherForegroundBrush}" />
    </Style>
    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="Foreground" Value="{StaticResource LauncherForegroundBrush}" />
    </Style>
    <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
        <Setter Property="Foreground" Value="{StaticResource LauncherForegroundBrush}" />
    </Style>
    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource LauncherForegroundBrush}" />
    </Style>

</ResourceDictionary>

<ui:ContentDialog x:Class="Launcher.App.Views.InstallToInstanceDialog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:viewModels="clr-namespace:Launcher.App.ViewModels"
      xmlns:converters="clr-namespace:Launcher.App.Converters"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=viewModels:InstallToInstanceViewModel}"
      Style="{StaticResource {x:Type ui:ContentDialog}}"
      Title="Установка проекта"
      CloseButtonText="Закрыть"
      DialogWidth="520"
      DialogMaxHeight="640">

    <ui:ContentDialog.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis" />
        <converters:EnumEqualsConverter x:Key="EnumEquals" />
        <converters:ZeroCountToVisibilityConverter x:Key="ZeroCountToVis" />

        <Style x:Key="ModeToggleStyle" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Appearance" Value="Secondary" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
    </ui:ContentDialog.Resources>

    <StackPanel Margin="0,8,0,0">
        <TextBlock Text="Тип сборки" Margin="0,0,0,8" FontSize="12"
                   Foreground="{StaticResource LauncherMutedForegroundBrush}" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <ui:Button Content="Существующая сборка" Command="{Binding SelectExistingCommand}">
                <ui:Button.Style>
                    <Style TargetType="ui:Button" BasedOn="{StaticResource ModeToggleStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsNewInstanceMode}" Value="False">
                                <Setter Property="Appearance" Value="Primary" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:Button.Style>
            </ui:Button>
            <ui:Button Content="Новая сборка" Command="{Binding SelectNewCommand}">
                <ui:Button.Style>
                    <Style TargetType="ui:Button" BasedOn="{StaticResource ModeToggleStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsNewInstanceMode}" Value="True">
                                <Setter Property="Appearance" Value="Primary" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:Button.Style>
            </ui:Button>
        </StackPanel>

        <Border Height="1" Background="{StaticResource LauncherHairlineBrush}" Margin="0,0,0,16" />

        <!-- Existing instance -->
        <StackPanel Visibility="{Binding IsNewInstanceMode, Converter={StaticResource InverseBoolToVis}}">
            <TextBox
                Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                Margin="0,0,0,12" />

            <ItemsControl ItemsSource="{Binding FilteredOptions}" MaxHeight="360">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:InstanceInstallOption}">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                Width="40" Height="40"
                                CornerRadius="8"
                                Background="{StaticResource LauncherSurfaceMutedBrush}">
                                <ui:SymbolIcon
                                    Symbol="CubeMultiple24"
                                    FontSize="18"
                                    Foreground="{StaticResource LauncherAccentSoftBrush}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>

                            <TextBlock
                                Grid.Column="2"
                                Text="{Binding Instance.Name}"
                                VerticalAlignment="Center"
                                FontWeight="Medium"
                                TextTrimming="CharacterEllipsis" />

                            <ui:Button
                                Grid.Column="3"
                                VerticalAlignment="Center"
                                Command="{Binding DataContext.InstallIntoCommand, RelativeSource={RelativeSource AncestorType={x:Type ui:ContentDialog}}}"
                                CommandParameter="{Binding}">
                                <ui:Button.Style>
                                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                        <Setter Property="Content" Value="Установить" />
                                        <Setter Property="Appearance" Value="Secondary" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInstalling}" Value="True">
                                                <Setter Property="Content" Value="Установка..." />
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsCompatible}" Value="False">
                                                <Setter Property="Content" Value="⚠ Установить" />
                                                <Setter Property="Foreground" Value="#F59E0B" />
                                                <Setter Property="BorderBrush" Value="#F59E0B" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                <Setter Property="Content" Value="✓ Установлено" />
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ui:Button.Style>
                            </ui:Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock
                Text="Нет доступных сборок — создайте новую."
                Foreground="{StaticResource LauncherMutedForegroundBrush}"
                Visibility="{Binding FilteredOptions.Count, Converter={StaticResource ZeroCountToVis}}" />

            <TextBlock
                Margin="0,8,0,0"
                FontSize="12"
                Foreground="{StaticResource LauncherMutedForegroundBrush}"
                Text="{Binding CompatibleCountLabel, Mode=OneWay}" />
        </StackPanel>

        <!-- New instance -->
        <StackPanel Visibility="{Binding IsNewInstanceMode, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Название" Margin="0,0,0,4" />
            <TextBox Text="{Binding NewInstance.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" />

            <TextBlock Text="Загрузчик" Margin="0,0,0,8" />
            <WrapPanel Margin="0,0,0,16">
                <RadioButton
                    Content="Fabric" GroupName="InstallDialogLoader" Margin="0,0,16,8"
                    IsChecked="{Binding NewInstance.SelectedLoaderType, Converter={StaticResource EnumEquals}, ConverterParameter=Fabric}" />
                <RadioButton
                    Content="Quilt" GroupName="InstallDialogLoader" Margin="0,0,16,8"
                    IsChecked="{Binding NewInstance.SelectedLoaderType, Converter={StaticResource EnumEquals}, ConverterParameter=Quilt}" />
                <RadioButton
                    Content="Forge" GroupName="InstallDialogLoader" Margin="0,0,16,8"
                    IsChecked="{Binding NewInstance.SelectedLoaderType, Converter={StaticResource EnumEquals}, ConverterParameter=Forge}" />
            </WrapPanel>

            <TextBlock Text="Версия игры" Margin="0,0,0,4" />
            <ComboBox
                ItemsSource="{Binding NewInstance.GameVersions}"
                SelectedItem="{Binding NewInstance.SelectedGameVersion}"
                DisplayMemberPath="Id"
                Margin="0,0,0,16" />

            <ui:Button
                Content="Установить"
                Appearance="Primary"
                HorizontalAlignment="Right"
                Command="{Binding CreateAndInstallCommand}" />
        </StackPanel>

        <TextBlock
            Text="{Binding StatusText}"
            FontSize="12"
            TextWrapping="Wrap"
            Margin="0,16,0,0"
            Foreground="{StaticResource LauncherMutedForegroundBrush}"
            Visibility="{Binding StatusText, Converter={StaticResource StringNotEmptyToVis}}" />
    </StackPanel>
</ui:ContentDialog>

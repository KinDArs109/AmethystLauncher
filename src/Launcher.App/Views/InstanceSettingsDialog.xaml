<ui:ContentDialog x:Class="Launcher.App.Views.InstanceSettingsDialog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:viewModels="clr-namespace:Launcher.App.ViewModels"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=viewModels:InstanceSettingsTabViewModel}"
      Style="{StaticResource {x:Type ui:ContentDialog}}"
      Title="Настройки сборки"
      CloseButtonText="Закрыть"
      DialogWidth="640"
      DialogMaxHeight="640">

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="560">
        <StackPanel Margin="0,8,4,0">

            <TextBlock Text="Группа в Библиотеке" FontSize="15" FontWeight="SemiBold" Margin="4,0,0,10" />
            <TextBox Text="{Binding GroupTag, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,24" />

            <!-- RAM -->
            <Border Style="{StaticResource LauncherGlassCardStyle}" Padding="18" Margin="0,0,0,16">
                <StackPanel>
                    <CheckBox Content="Своё количество памяти" Style="{StaticResource LauncherToggleSwitchStyle}" IsChecked="{Binding UseCustomRam}" Margin="0,0,0,4" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{StaticResource LauncherMutedForegroundBrush}"
                        Margin="0,0,0,12">
                        <Run Text="Иначе используется глобальное значение из Настроек лаунчера:" />
                        <Run Text="{Binding GlobalMinRamMb, Mode=OneWay}" />
                        <Run Text="–" />
                        <Run Text="{Binding GlobalMaxRamMb, Mode=OneWay}" />
                        <Run Text="МБ" />
                    </TextBlock>
                    <StackPanel
                        Orientation="Horizontal"
                        IsEnabled="{Binding UseCustomRam}">
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="Минимум, МБ" FontSize="12" Foreground="{StaticResource LauncherMutedForegroundBrush}" Margin="0,0,0,4" />
                            <ui:NumberBox Value="{Binding MinRamMb}" Minimum="256" Maximum="65536" Width="140" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Максимум, МБ" FontSize="12" Foreground="{StaticResource LauncherMutedForegroundBrush}" Margin="0,0,0,4" />
                            <ui:NumberBox Value="{Binding MaxRamMb}" Minimum="256" Maximum="65536" Width="140" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Java -->
            <Border Style="{StaticResource LauncherGlassCardStyle}" Padding="18" Margin="0,0,0,16">
                <StackPanel>
                    <CheckBox Content="Свой путь к Java" Style="{StaticResource LauncherToggleSwitchStyle}" IsChecked="{Binding UseCustomJava}" Margin="0,0,0,12" />
                    <Grid IsEnabled="{Binding UseCustomJava}" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding JavaPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                        <ui:Button Grid.Column="1" Content="Обзор..." Appearance="Secondary" Command="{Binding BrowseJavaCommand}" />
                    </Grid>

                    <TextBlock Text="Дополнительные аргументы JVM" FontSize="12" Foreground="{StaticResource LauncherMutedForegroundBrush}" Margin="0,0,0,4" />
                    <TextBox
                        Text="{Binding JvmArgs, UpdateSourceTrigger=PropertyChanged}"
                        AcceptsReturn="False"
                        TextWrapping="Wrap"
                        MinHeight="60" />
                </StackPanel>
            </Border>

            <!-- Window -->
            <Border Style="{StaticResource LauncherGlassCardStyle}" Padding="18" Margin="0,0,0,16">
                <StackPanel>
                    <CheckBox Content="Свой размер окна" Style="{StaticResource LauncherToggleSwitchStyle}" IsChecked="{Binding UseCustomWindow}" Margin="0,0,0,12" />
                    <StackPanel
                        Orientation="Horizontal"
                        Margin="0,0,0,12"
                        IsEnabled="{Binding UseCustomWindow}">
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="Ширина" FontSize="12" Foreground="{StaticResource LauncherMutedForegroundBrush}" Margin="0,0,0,4" />
                            <ui:NumberBox Value="{Binding WindowWidth}" Minimum="320" Maximum="7680" Width="140" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Высота" FontSize="12" Foreground="{StaticResource LauncherMutedForegroundBrush}" Margin="0,0,0,4" />
                            <ui:NumberBox Value="{Binding WindowHeight}" Minimum="240" Maximum="4320" Width="140" />
                        </StackPanel>
                    </StackPanel>
                    <CheckBox Content="Полноэкранный режим" Style="{StaticResource LauncherToggleSwitchStyle}" IsChecked="{Binding Fullscreen}" />
                </StackPanel>
            </Border>

            <!-- Env vars -->
            <Border Style="{StaticResource LauncherGlassCardStyle}" Padding="18" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Переменные среды" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock
                        Text="По одной на строку, в формате КЛЮЧ=значение"
                        FontSize="12"
                        Foreground="{StaticResource LauncherMutedForegroundBrush}"
                        Margin="0,0,0,10" />
                    <TextBox
                        Text="{Binding EnvVarsText, UpdateSourceTrigger=PropertyChanged}"
                        AcceptsReturn="True"
                        TextWrapping="NoWrap"
                        FontFamily="Consolas"
                        MinHeight="90"
                        VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal">
                <ui:Button
                    Content="Сохранить настройки"
                    Appearance="Primary"
                    Style="{StaticResource LauncherGlowButtonStyle}"
                    Icon="{ui:SymbolIcon Save24}"
                    Command="{Binding SaveCommand}"
                    Margin="0,0,12,0" />
                <TextBlock
                    Text="{Binding StatusText}"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource LauncherMutedForegroundBrush}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</ui:ContentDialog>

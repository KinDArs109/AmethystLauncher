<Page x:Class="Launcher.App.Views.Pages.AccountsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:viewModels="clr-namespace:Launcher.App.ViewModels"
      xmlns:converters="clr-namespace:Launcher.App.Converters"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=viewModels:AccountsViewModel}"
      d:DesignWidth="900" d:DesignHeight="600"
      Title="AccountsPage"
      Opacity="0"
      RenderTransformOrigin="0.5,0.5">

    <Page.RenderTransform>
        <TranslateTransform Y="14" />
    </Page.RenderTransform>
    <Page.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PageEnterStoryboard}" />
        </EventTrigger>
    </Page.Triggers>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter" />
    </Page.Resources>

    <Grid Margin="40,32,40,32">
        <StackPanel MaxWidth="480" HorizontalAlignment="Left">
            <TextBlock Text="Аккаунты" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24" />

            <!-- Nickname -->
            <Border
                CornerRadius="12"
                Background="{StaticResource LauncherSurfaceBrush}"
                BorderBrush="{StaticResource LauncherHairlineBrush}"
                BorderThickness="1"
                Padding="20"
                Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Никнейм" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock
                        Text="Имя, под которым тебя видят в игре."
                        FontSize="12"
                        Foreground="{StaticResource LauncherMutedForegroundBrush}"
                        Margin="0,0,0,12" />
                    <TextBox
                        Style="{StaticResource LauncherFloatingLabelInputStyle}"
                        Tag="Никнейм"
                        Text="{Binding ViewModel.Nickname, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Border>

            <!-- Local (username+password) account — stored in the launcher's cloud (Supabase), so it
                 survives reinstall and works from any computer. -->
            <Border
                CornerRadius="12"
                Background="{StaticResource LauncherSurfaceBrush}"
                BorderBrush="{StaticResource LauncherHairlineBrush}"
                BorderThickness="1"
                Padding="20"
                Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Аккаунт лаунчера" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock
                        Text="Хранится в облаке лаунчера — переустановка или другой компьютер не страшны. Не связан с Microsoft или Mojang."
                        FontSize="12"
                        Foreground="{StaticResource LauncherMutedForegroundBrush}"
                        TextWrapping="Wrap"
                        Margin="0,0,0,16" />

                    <!-- Signed in -->
                    <StackPanel Visibility="{Binding ViewModel.IsLocalSignedIn, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <ui:SymbolIcon Symbol="Person24" Foreground="{StaticResource LauncherAccentSoftBrush}" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding ViewModel.LocalSignedInUsername}" FontWeight="SemiBold" />
                        </StackPanel>
                        <ui:Button Content="Выйти" Command="{Binding ViewModel.LocalSignOutCommand}" HorizontalAlignment="Left" Margin="0,12,0,0" />
                    </StackPanel>

                    <!-- Login / register form — recolored uiverse.io/bociKond/dull-mole-77, inputs use
                         LauncherFloatingLabelInputStyle/…PasswordStyle (uiverse.io/liyaxu123/warm-eel-62). -->
                    <StackPanel
                        MaxWidth="300"
                        Visibility="{Binding ViewModel.IsLocalSignedIn, Converter={StaticResource InverseBoolToVis}}">
                        <TextBox
                            Style="{StaticResource LauncherFloatingLabelInputStyle}"
                            Tag="Имя пользователя"
                            Text="{Binding ViewModel.LocalUsername, UpdateSourceTrigger=PropertyChanged}"
                            Margin="0,0,0,6" />
                        <PasswordBox
                            x:Name="LocalPasswordBox"
                            Style="{StaticResource LauncherFloatingLabelPasswordStyle}"
                            Tag="Пароль"
                            Margin="0,0,0,6"
                            PasswordChanged="LocalPasswordBox_PasswordChanged" />
                        <PasswordBox
                            x:Name="LocalConfirmPasswordBox"
                            Style="{StaticResource LauncherFloatingLabelPasswordStyle}"
                            Tag="Повторите пароль"
                            Margin="0,0,0,6"
                            Visibility="{Binding ViewModel.IsRegisterMode, Converter={StaticResource BoolToVis}}"
                            PasswordChanged="LocalConfirmPasswordBox_PasswordChanged" />

                        <Button
                            Style="{StaticResource LauncherAuthPillButtonStyle}"
                            Content="Войти"
                            Margin="0,10,0,0"
                            Command="{Binding ViewModel.LocalSignInCommand}"
                            Visibility="{Binding ViewModel.IsRegisterMode, Converter={StaticResource InverseBoolToVis}}" />
                        <Button
                            Style="{StaticResource LauncherAuthPillButtonStyle}"
                            Content="Зарегистрироваться"
                            Margin="0,10,0,0"
                            Command="{Binding ViewModel.LocalRegisterCommand}"
                            Visibility="{Binding ViewModel.IsRegisterMode, Converter={StaticResource BoolToVis}}" />

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                            <TextBlock
                                Text="Нет аккаунта?"
                                FontSize="12"
                                Foreground="{StaticResource LauncherMutedForegroundBrush}"
                                Margin="0,0,4,0"
                                Visibility="{Binding ViewModel.IsRegisterMode, Converter={StaticResource InverseBoolToVis}}" />
                            <TextBlock
                                Text="Уже есть аккаунт?"
                                FontSize="12"
                                Foreground="{StaticResource LauncherMutedForegroundBrush}"
                                Margin="0,0,4,0"
                                Visibility="{Binding ViewModel.IsRegisterMode, Converter={StaticResource BoolToVis}}" />
                            <ui:Button
                                Appearance="Transparent"
                                Padding="0"
                                FontSize="12"
                                Foreground="{StaticResource LauncherAccentSoftBrush}"
                                Content="Зарегистрироваться"
                                Command="{Binding ViewModel.ToggleAuthModeCommand}"
                                Visibility="{Binding ViewModel.IsRegisterMode, Converter={StaticResource InverseBoolToVis}}" />
                            <ui:Button
                                Appearance="Transparent"
                                Padding="0"
                                FontSize="12"
                                Foreground="{StaticResource LauncherAccentSoftBrush}"
                                Content="Войти"
                                Command="{Binding ViewModel.ToggleAuthModeCommand}"
                                Visibility="{Binding ViewModel.IsRegisterMode, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <ui:ProgressRing
                                IsIndeterminate="True"
                                Width="14" Height="14"
                                Margin="0,0,8,0"
                                Visibility="{Binding ViewModel.IsLocalBusy, Converter={StaticResource BoolToVis}}" />
                            <TextBlock
                                Text="{Binding ViewModel.LocalStatusText}"
                                TextWrapping="Wrap"
                                FontSize="12"
                                Foreground="{StaticResource LauncherMutedForegroundBrush}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Skin (needs a signed-in launcher account — the skin is tied to that username) -->
            <Border
                Visibility="{Binding ViewModel.IsLocalSignedIn, Converter={StaticResource BoolToVis}}"
                CornerRadius="12"
                Background="{StaticResource LauncherSurfaceBrush}"
                BorderBrush="{StaticResource LauncherHairlineBrush}"
                BorderThickness="1"
                Padding="20"
                Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Скин" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock
                        Text="Загрузи PNG-скин (64×64) — он появится в игре у тебя и у других игроков лаунчера на серверах."
                        FontSize="12"
                        Foreground="{StaticResource LauncherMutedForegroundBrush}"
                        TextWrapping="Wrap"
                        Margin="0,0,0,14" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Pixel head preview -->
                        <Border
                            Grid.Column="0"
                            Width="64" Height="64"
                            CornerRadius="10"
                            Background="{StaticResource LauncherSurfaceMutedBrush}"
                            BorderBrush="{StaticResource LauncherHairlineBrush}"
                            BorderThickness="1">
                            <Grid>
                                <ui:SymbolIcon
                                    Symbol="Person24"
                                    FontSize="26"
                                    Foreground="{StaticResource LauncherMutedForegroundBrush}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding ViewModel.HasSkin, Converter={StaticResource InverseBoolToVis}}" />
                                <Image
                                    Source="{Binding ViewModel.SkinHeadPreview}"
                                    Width="56" Height="56"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                                    Visibility="{Binding ViewModel.HasSkin, Converter={StaticResource BoolToVis}}" />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton
                                    Content="Steve"
                                    GroupName="SkinModel"
                                    IsChecked="{Binding ViewModel.IsSkinSlim, Converter={StaticResource InverseBoolConverter}}"
                                    Margin="0,0,14,0" />
                                <RadioButton
                                    Content="Alex"
                                    GroupName="SkinModel"
                                    IsChecked="{Binding ViewModel.IsSkinSlim}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ui:Button
                                    Content="Загрузить скин"
                                    Appearance="Primary"
                                    Icon="{ui:SymbolIcon ArrowUpload24}"
                                    Command="{Binding ViewModel.UploadSkinCommand}"
                                    Margin="0,0,10,0" />
                                <ui:Button
                                    Content="Удалить"
                                    Icon="{ui:SymbolIcon Delete24}"
                                    Command="{Binding ViewModel.DeleteSkinCommand}"
                                    Visibility="{Binding ViewModel.HasSkin, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <ui:ProgressRing
                            IsIndeterminate="True"
                            Width="14" Height="14"
                            Margin="0,0,8,0"
                            Visibility="{Binding ViewModel.IsSkinBusy, Converter={StaticResource BoolToVis}}" />
                        <TextBlock
                            Text="{Binding ViewModel.SkinStatusText}"
                            TextWrapping="Wrap"
                            FontSize="12"
                            Foreground="{StaticResource LauncherMutedForegroundBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</Page>

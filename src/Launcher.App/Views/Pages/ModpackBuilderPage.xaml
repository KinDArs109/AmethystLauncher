<Page x:Class="Launcher.App.Views.Pages.ModpackBuilderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:viewModels="clr-namespace:Launcher.App.ViewModels"
      xmlns:converters="clr-namespace:Launcher.App.Converters"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=viewModels:ModpackBuilderViewModel}"
      d:DesignWidth="1100" d:DesignHeight="640"
      Title="ModpackBuilderPage"
      Opacity="0"
      RenderTransformOrigin="0.5,0.5">

    <Page.RenderTransform>
        <TranslateTransform Y="14" />
    </Page.RenderTransform>
    <Page.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PageEnterStoryboard}" />
        </EventTrigger>
    </Page.Triggers>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis" />
        <converters:ZeroCountToVisibilityConverter x:Key="ZeroCountToVis" />
        <converters:NonZeroCountToVisibilityConverter x:Key="NonZeroCountToVis" />

        <!-- Fade+rise used when a node's panel becomes active. -->
        <Storyboard x:Key="NodePanelEnter">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.28" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="16" To="0" Duration="0:0:0.32">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Base look shared by the four orbital node buttons. -->
        <Style x:Key="OrbitNodeText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CFC3EC" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,7,0,0" />
        </Style>

        <!-- Style for a node panel: collapsed unless its node is active; fades in when shown. The
             RenderTransform is set inline on each panel (not here) so every panel gets its own mutable
             TranslateTransform — a shared one from a Style setter is frozen and can't be animated. -->
        <Style x:Key="NodePanelStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="Opacity" Value="0" />
        </Style>
    </Page.Resources>

    <Grid ClipToBounds="True" MouseMove="OnRootMouseMove" Background="Transparent">

        <!-- 1) Animated gradient backdrop: breathes between dark-violet and near-black — only on this page.
             The stops are animated via an indexed property path on the named Border (naming the
             GradientStops directly isn't reachable from this trigger's namescope). -->
        <Border x:Name="BgBorder">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#241A47" Offset="0" />
                    <GradientStop Color="#0D0A19" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <ColorAnimation Storyboard.TargetName="BgBorder"
                                            Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[0].(GradientStop.Color)"
                                            To="#3C2478" Duration="0:0:7" />
                            <ColorAnimation Storyboard.TargetName="BgBorder"
                                            Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[1].(GradientStop.Color)"
                                            To="#151026" Duration="0:0:7" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
        </Border>

        <!-- 2) Dot-field: filled from code-behind, brightens near the cursor. -->
        <Canvas x:Name="DotCanvas" IsHitTestVisible="False" />

        <!-- 3) Content -->
        <Grid Margin="40,26,40,26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Конструктор сборок" FontSize="28" FontWeight="SemiBold" Foreground="White" />
                <TextBlock Text="Выбери действие на орбите: создать или выбрать сборку, добавить моды, править конфиги, протестировать."
                           FontSize="13" Foreground="#A99AD0" Margin="0,4,0,0" />
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="470" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ===== Orbital cluster ===== -->
                <Grid Grid.Column="0" Width="460" Height="460" HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- rotating dashed orbit ring -->
                    <Ellipse Width="320" Height="320" HorizontalAlignment="Center" VerticalAlignment="Center"
                             Stroke="#5A4694" StrokeThickness="1.4" StrokeDashArray="1 7" StrokeDashCap="Round"
                             RenderTransformOrigin="0.5,0.5" Opacity="0.9">
                        <Ellipse.RenderTransform><RotateTransform x:Name="OrbitRotate" /></Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="OrbitRotate" Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:48" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <Ellipse Width="210" Height="210" HorizontalAlignment="Center" VerticalAlignment="Center"
                             Stroke="#40356B" StrokeThickness="1" Opacity="0.7" />

                    <!-- central hub: current build state -->
                    <Border Width="168" Height="168" CornerRadius="84" HorizontalAlignment="Center" VerticalAlignment="Center"
                            BorderBrush="#6C55B8" BorderThickness="1.5">
                        <Border.Background>
                            <RadialGradientBrush>
                                <GradientStop Color="#2A1F55" Offset="0" />
                                <GradientStop Color="#171233" Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center" Margin="14,0">
                            <ui:SymbolIcon Symbol="Wrench24" FontSize="26" Foreground="#B79BF3" HorizontalAlignment="Center" />
                            <TextBlock Text="Сборка" FontSize="11" Foreground="#8E7EC0" HorizontalAlignment="Center" Margin="0,6,0,2" />
                            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold" FontSize="13"
                                       Foreground="White" TextTrimming="CharacterEllipsis" MaxWidth="140">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="не выбрана" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ViewModel.HasWorkingInstance}" Value="True">
                                                <Setter Property="Text" Value="{Binding ViewModel.WorkingInstance.Name}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Node: Создать (top) -->
                    <Button VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,6,0,0"
                            Command="{Binding ViewModel.SelectNodeCommand}"
                            CommandParameter="{x:Static viewModels:BuilderNode.Create}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <StackPanel Background="Transparent">
                                    <Border x:Name="Ring" Width="70" Height="70" CornerRadius="35" HorizontalAlignment="Center"
                                            Background="#221A44" BorderBrush="#4C3D82" BorderThickness="1.5">
                                        <ui:SymbolIcon Symbol="Add24" FontSize="24" Foreground="#C9BAF5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Создать" Style="{StaticResource OrbitNodeText}" />
                                </StackPanel>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Ring" Property="BorderBrush" Value="#8B6FE0" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding ViewModel.ActiveNode}" Value="Create">
                                        <Setter TargetName="Ring" Property="Background" Value="{StaticResource LauncherAccentGradientBrush}" />
                                        <Setter TargetName="Ring" Property="BorderBrush" Value="#B79BF3" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Node: Моды (right) -->
                    <Button VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,6,0"
                            Command="{Binding ViewModel.SelectNodeCommand}"
                            CommandParameter="{x:Static viewModels:BuilderNode.Mods}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <StackPanel Background="Transparent">
                                    <Border x:Name="Ring" Width="70" Height="70" CornerRadius="35" HorizontalAlignment="Center"
                                            Background="#221A44" BorderBrush="#4C3D82" BorderThickness="1.5">
                                        <ui:SymbolIcon Symbol="BoxMultiple24" FontSize="24" Foreground="#C9BAF5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Моды" Style="{StaticResource OrbitNodeText}" />
                                </StackPanel>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Ring" Property="BorderBrush" Value="#8B6FE0" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding ViewModel.ActiveNode}" Value="Mods">
                                        <Setter TargetName="Ring" Property="Background" Value="{StaticResource LauncherAccentGradientBrush}" />
                                        <Setter TargetName="Ring" Property="BorderBrush" Value="#B79BF3" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Node: Конфиги (left) -->
                    <Button VerticalAlignment="Center" HorizontalAlignment="Left" Margin="6,0,0,0"
                            Command="{Binding ViewModel.SelectNodeCommand}"
                            CommandParameter="{x:Static viewModels:BuilderNode.Configs}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <StackPanel Background="Transparent">
                                    <Border x:Name="Ring" Width="70" Height="70" CornerRadius="35" HorizontalAlignment="Center"
                                            Background="#221A44" BorderBrush="#4C3D82" BorderThickness="1.5">
                                        <ui:SymbolIcon Symbol="Settings24" FontSize="24" Foreground="#C9BAF5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Конфиги" Style="{StaticResource OrbitNodeText}" />
                                </StackPanel>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Ring" Property="BorderBrush" Value="#8B6FE0" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding ViewModel.ActiveNode}" Value="Configs">
                                        <Setter TargetName="Ring" Property="Background" Value="{StaticResource LauncherAccentGradientBrush}" />
                                        <Setter TargetName="Ring" Property="BorderBrush" Value="#B79BF3" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Node: Тест (bottom) -->
                    <Button VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,6"
                            Command="{Binding ViewModel.SelectNodeCommand}"
                            CommandParameter="{x:Static viewModels:BuilderNode.Test}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <StackPanel Background="Transparent">
                                    <Border x:Name="Ring" Width="70" Height="70" CornerRadius="35" HorizontalAlignment="Center"
                                            Background="#221A44" BorderBrush="#4C3D82" BorderThickness="1.5">
                                        <ui:SymbolIcon Symbol="Play24" FontSize="24" Foreground="#C9BAF5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Тест" Style="{StaticResource OrbitNodeText}" />
                                </StackPanel>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Ring" Property="BorderBrush" Value="#8B6FE0" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding ViewModel.ActiveNode}" Value="Test">
                                        <Setter TargetName="Ring" Property="Background" Value="{StaticResource LauncherAccentGradientBrush}" />
                                        <Setter TargetName="Ring" Property="BorderBrush" Value="#B79BF3" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- ===== Active node panel ===== -->
                <Border Grid.Column="1" Margin="12,0,0,0" CornerRadius="16" Padding="22"
                        Background="#B3140E28" BorderBrush="#332A57" BorderThickness="1">
                    <Grid>
                        <!-- CREATE -->
                        <Grid>
                            <Grid.RenderTransform><TranslateTransform Y="16" /></Grid.RenderTransform>
                            <Grid.Style>
                                <Style TargetType="Grid" BasedOn="{StaticResource NodePanelStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewModel.ActiveNode}" Value="Create">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Storyboard="{StaticResource NodePanelEnter}" />
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Создать или выбрать сборку" FontSize="17" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4" />
                                    <TextBlock Text="Начни новую сборку или открой уже существующую, чтобы доработать её." FontSize="12.5" Foreground="#A99AD0" Margin="0,0,0,14" TextWrapping="Wrap" />

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <ui:Button Content="Новая" Command="{Binding ViewModel.SetCreateModeCommand}" Margin="0,0,8,0" Padding="16,7">
                                            <ui:Button.Style>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                    <Setter Property="Appearance" Value="Secondary" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ViewModel.IsEditMode}" Value="False">
                                                            <Setter Property="Appearance" Value="Primary" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                        </ui:Button>
                                        <ui:Button Content="Существующая" Command="{Binding ViewModel.SetEditModeCommand}" Padding="16,7">
                                            <ui:Button.Style>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                    <Setter Property="Appearance" Value="Secondary" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ViewModel.IsEditMode}" Value="True">
                                                            <Setter Property="Appearance" Value="Primary" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:Button.Style>
                                        </ui:Button>
                                    </StackPanel>

                                    <!-- New build -->
                                    <StackPanel Visibility="{Binding ViewModel.IsEditMode, Converter={StaticResource InverseBoolToVis}}">
                                        <TextBlock Text="Название" FontSize="12" Foreground="#A99AD0" Margin="0,0,0,4" />
                                        <ui:TextBox Text="{Binding ViewModel.Name, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Моя сборка" Margin="0,0,0,12" />
                                        <TextBlock Text="Версия Minecraft" FontSize="12" Foreground="#A99AD0" Margin="0,0,0,4" />
                                        <ComboBox ItemsSource="{Binding ViewModel.GameVersions}" SelectedItem="{Binding ViewModel.SelectedGameVersion}" DisplayMemberPath="Id" Margin="0,0,0,12" />
                                        <TextBlock Text="Загрузчик модов" FontSize="12" Foreground="#A99AD0" Margin="0,0,0,4" />
                                        <ComboBox ItemsSource="{Binding ViewModel.LoaderTypes}" SelectedItem="{Binding ViewModel.SelectedLoaderType}" />
                                    </StackPanel>

                                    <!-- Existing build -->
                                    <StackPanel Visibility="{Binding ViewModel.IsEditMode, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Какую сборку дорабатываем?" FontSize="12" Foreground="#A99AD0" Margin="0,0,0,4" />
                                        <ComboBox ItemsSource="{Binding ViewModel.EditableInstances}" SelectedItem="{Binding ViewModel.SelectedEditInstance}" DisplayMemberPath="Name" />
                                    </StackPanel>

                                    <ui:InfoBar IsOpen="True" Severity="Informational" Margin="0,16,0,0" IsClosable="False"
                                                Title="Дальше" Message="Перейди к узлу «Моды», чтобы добавить содержимое и сохранить сборку." />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- MODS -->
                        <Grid>
                            <Grid.RenderTransform><TranslateTransform Y="16" /></Grid.RenderTransform>
                            <Grid.Style>
                                <Style TargetType="Grid" BasedOn="{StaticResource NodePanelStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewModel.ActiveNode}" Value="Mods">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Storyboard="{StaticResource NodePanelEnter}" />
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Добавление модов" FontSize="17" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,10" />

                                <!-- live search -->
                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                    <ui:TextBox Text="{Binding ViewModel.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="Живой поиск модов на Modrinth..." Icon="{ui:SymbolIcon Search24}" />
                                </Grid>

                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <ui:ProgressRing IsIndeterminate="True" Width="18" Height="18" HorizontalAlignment="Left" Margin="0,0,0,8"
                                                         Visibility="{Binding ViewModel.IsSearching, Converter={StaticResource BoolToVis}}" />

                                        <!-- search results -->
                                        <ItemsControl ItemsSource="{Binding ViewModel.SearchResults}"
                                                      Visibility="{Binding ViewModel.SearchResults.Count, Converter={StaticResource NonZeroCountToVis}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#22FFFFFF" CornerRadius="9" Padding="10" Margin="0,0,0,7">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="10" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Width="34" Height="34" CornerRadius="7" Background="#33000000">
                                                                <Border CornerRadius="7">
                                                                    <Border.Background>
                                                                        <ImageBrush ImageSource="{Binding IconUrl}" Stretch="UniformToFill" />
                                                                    </Border.Background>
                                                                </Border>
                                                            </Border>
                                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" Foreground="White" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#A99AD0" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                            <ui:Button Grid.Column="3" Appearance="Primary" Padding="6" ToolTip="Добавить в сборку"
                                                                       Icon="{ui:SymbolIcon Add24}"
                                                                       Command="{Binding ViewModel.AddModCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                       CommandParameter="{Binding}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- draft -->
                                        <TextBlock Margin="0,6,0,8" FontWeight="SemiBold" Foreground="White">
                                            <Run Text="В сборке" /><Run Text=" (" /><Run Text="{Binding ViewModel.DraftMods.Count, Mode=OneWay}" /><Run Text=")" />
                                        </TextBlock>
                                        <TextBlock Text="Пока пусто — найди мод выше и нажми «+»." FontSize="12" Foreground="#A99AD0"
                                                   Visibility="{Binding ViewModel.DraftMods.Count, Converter={StaticResource ZeroCountToVis}}" />

                                        <ItemsControl ItemsSource="{Binding ViewModel.FilteredDraftMods}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#1AFFFFFF" CornerRadius="9" Padding="10" Margin="0,0,0,7">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="8" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="4" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" Foreground="White" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="Нет версии под конфигурацию" FontSize="11" Foreground="#F87171"
                                                                           Visibility="{Binding IsIncompatible, Converter={StaticResource BoolToVis}}" />
                                                            </StackPanel>
                                                            <ComboBox Grid.Column="1" Width="140" ItemsSource="{Binding AvailableVersions}" SelectedItem="{Binding SelectedVersion}"
                                                                      DisplayMemberPath="VersionNumber" VerticalAlignment="Center"
                                                                      Visibility="{Binding IsIncompatible, Converter={StaticResource InverseBoolToVis}}" />
                                                            <CheckBox Grid.Column="3" IsChecked="{Binding IsEnabled}" ToolTip="Включён" VerticalAlignment="Center" />
                                                            <ui:Button Grid.Column="5" Appearance="Transparent" Padding="4" ToolTip="Убрать"
                                                                       Icon="{ui:SymbolIcon Delete24}"
                                                                       Command="{Binding ViewModel.RemoveModCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                       CommandParameter="{Binding}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>

                                <StackPanel Grid.Row="3" Margin="0,12,0,0">
                                    <ui:Button Content="{Binding ViewModel.SaveButtonText}" Style="{StaticResource LauncherGlowButtonStyle}"
                                               Icon="{ui:SymbolIcon Checkmark24}" HorizontalAlignment="Stretch"
                                               Command="{Binding ViewModel.SaveCommand}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                Visibility="{Binding ViewModel.StatusText, Converter={StaticResource StringNotEmptyToVis}}">
                                        <ui:ProgressRing IsIndeterminate="True" Width="13" Height="13" Margin="0,1,8,0" VerticalAlignment="Top"
                                                         Visibility="{Binding ViewModel.IsBusy, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Text="{Binding ViewModel.StatusText}" FontSize="12" TextWrapping="Wrap" Foreground="#C9BEE4" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- CONFIGS -->
                        <Grid>
                            <Grid.RenderTransform><TranslateTransform Y="16" /></Grid.RenderTransform>
                            <Grid.Style>
                                <Style TargetType="Grid" BasedOn="{StaticResource NodePanelStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewModel.ActiveNode}" Value="Configs">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Storyboard="{StaticResource NodePanelEnter}" />
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <StackPanel>
                                <TextBlock Text="Изменение конфигов" FontSize="17" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,6" />
                                <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="#A99AD0" Margin="0,0,0,14"
                                           Text="Конфиги модов лежат в папке /config сборки и создаются после первого запуска игры. Открой файлы сборки, чтобы отредактировать их прямо в лаунчере." />
                                <ui:Button Content="Открыть файлы сборки" Icon="{ui:SymbolIcon Open24}" Appearance="Primary"
                                           HorizontalAlignment="Left" Command="{Binding ViewModel.OpenConfigsCommand}" />
                                <TextBlock Margin="0,12,0,0" FontSize="12" Foreground="#F0B45A"
                                           Text="Сначала создай или выбери сборку в узле «Создать»."
                                           Visibility="{Binding ViewModel.HasWorkingInstance, Converter={StaticResource InverseBoolToVis}}" />
                            </StackPanel>
                        </Grid>

                        <!-- TEST -->
                        <Grid>
                            <Grid.RenderTransform><TranslateTransform Y="16" /></Grid.RenderTransform>
                            <Grid.Style>
                                <Style TargetType="Grid" BasedOn="{StaticResource NodePanelStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewModel.ActiveNode}" Value="Test">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Storyboard="{StaticResource NodePanelEnter}" />
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <StackPanel>
                                <TextBlock Text="Тестирование сборки" FontSize="17" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,6" />
                                <TextBlock TextWrapping="Wrap" FontSize="12.5" Foreground="#A99AD0" Margin="0,0,0,14"
                                           Text="Запусти сборку, чтобы проверить, что всё работает: моды загрузятся, игра стартует." />
                                <ui:Button Content="Запустить сборку" Icon="{ui:SymbolIcon Play24}" Style="{StaticResource LauncherGlowButtonStyle}"
                                           HorizontalAlignment="Left" Command="{Binding ViewModel.LaunchTestCommand}" />
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                            Visibility="{Binding ViewModel.StatusText, Converter={StaticResource StringNotEmptyToVis}}">
                                    <TextBlock Text="{Binding ViewModel.StatusText}" FontSize="12" TextWrapping="Wrap" Foreground="#C9BEE4" MaxWidth="360" />
                                </StackPanel>
                                <TextBlock Margin="0,12,0,0" FontSize="12" Foreground="#F0B45A"
                                           Text="Сначала создай или выбери сборку в узле «Создать»."
                                           Visibility="{Binding ViewModel.HasWorkingInstance, Converter={StaticResource InverseBoolToVis}}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>

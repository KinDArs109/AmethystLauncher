<Page x:Class="Launcher.App.Views.Pages.ModpackBuilderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:viewModels="clr-namespace:Launcher.App.ViewModels"
      xmlns:converters="clr-namespace:Launcher.App.Converters"
      xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=viewModels:ModpackBuilderViewModel}"
      d:DesignWidth="900" d:DesignHeight="600"
      Title="ModpackBuilderPage"
      Opacity="0"
      RenderTransformOrigin="0.5,0.5">

    <Page.RenderTransform>
        <TranslateTransform Y="14" />
    </Page.RenderTransform>
    <Page.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PageEnterStoryboard}" />
        </EventTrigger>
    </Page.Triggers>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis" />
        <converters:ZeroCountToVisibilityConverter x:Key="ZeroCountToVis" />
        <converters:NonZeroCountToVisibilityConverter x:Key="NonZeroCountToVis" />

        <Style x:Key="BuilderModePillStyle" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Appearance" Value="Secondary" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" behaviors:ScrollViewerWindowHeightBehavior.Enabled="True">
        <StackPanel Margin="40,32,40,32">
            <TextBlock Text="Конструктор сборок" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,6" />
            <TextBlock
                Text="Собери новую сборку или настрой существующую: моды, их версии, вкл/выкл — всё в одном месте."
                FontSize="13"
                Foreground="{StaticResource LauncherMutedForegroundBrush}"
                Margin="0,0,0,16" />

            <!-- Mode switch -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                <ui:Button Content="Новая сборка" Command="{Binding ViewModel.SetCreateModeCommand}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource BuilderModePillStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ViewModel.IsEditMode}" Value="False">
                                    <Setter Property="Appearance" Value="Primary" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Content="Изменить сборку" Command="{Binding ViewModel.SetEditModeCommand}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource BuilderModePillStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ViewModel.IsEditMode}" Value="True">
                                    <Setter Property="Appearance" Value="Primary" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left: pack parameters + save -->
                <StackPanel Grid.Column="0">
                    <!-- Create mode -->
                    <Border Style="{StaticResource LauncherGlassStaticCardStyle}" Padding="18" Margin="0,0,0,14"
                            Visibility="{Binding ViewModel.IsEditMode, Converter={StaticResource InverseBoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Параметры сборки" FontWeight="SemiBold" Margin="0,0,0,12" />

                            <TextBlock Text="Название" FontSize="12" Foreground="{StaticResource LauncherMutedForegroundBrush}" Margin="0,0,0,4" />
                            <ui:TextBox
                                Text="{Binding ViewModel.Name, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="Моя сборка"
                                Margin="0,0,0,12" />

                            <TextBlock Text="Версия Minecraft" FontSize="12" Foreground="{StaticResource LauncherMutedForegroundBrush}" Margin="0,0,0,4" />
                            <ComboBox
                                ItemsSource="{Binding ViewModel.GameVersions}"
                                SelectedItem="{Binding ViewModel.SelectedGameVersion}"
                                DisplayMemberPath="Id"
                                Margin="0,0,0,12" />

                            <TextBlock Text="Загрузчик модов" FontSize="12" Foreground="{StaticResource LauncherMutedForegroundBrush}" Margin="0,0,0,4" />
                            <ComboBox
                                ItemsSource="{Binding ViewModel.LoaderTypes}"
                                SelectedItem="{Binding ViewModel.SelectedLoaderType}" />
                        </StackPanel>
                    </Border>

                    <!-- Edit mode -->
                    <Border Style="{StaticResource LauncherGlassStaticCardStyle}" Padding="18" Margin="0,0,0,14"
                            Visibility="{Binding ViewModel.IsEditMode, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Какая сборка?" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <ComboBox
                                ItemsSource="{Binding ViewModel.EditableInstances}"
                                SelectedItem="{Binding ViewModel.SelectedEditInstance}"
                                DisplayMemberPath="Name"
                                Margin="0,0,0,10" />
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ViewModel.SelectedEditInstance}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ui:SymbolIcon Symbol="Folder24" FontSize="13" Foreground="{StaticResource LauncherMutedForegroundBrush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{StaticResource LauncherMutedForegroundBrush}"
                                    VerticalAlignment="Center">
                                    <Run Text="{Binding ViewModel.SelectedEditInstance.LoaderType, Mode=OneWay}" />
                                    <Run Text=" · " />
                                    <Run Text="{Binding ViewModel.SelectedEditInstance.VersionId, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <ui:Button
                        Content="{Binding ViewModel.SaveButtonText}"
                        Style="{StaticResource LauncherGlowButtonStyle}"
                        Icon="{ui:SymbolIcon Checkmark24}"
                        HorizontalAlignment="Stretch"
                        Command="{Binding ViewModel.SaveCommand}"
                        Margin="0,0,0,10" />

                    <ui:Button
                        Content="Открыть сборку"
                        Icon="{ui:SymbolIcon Open24}"
                        HorizontalAlignment="Stretch"
                        Command="{Binding ViewModel.OpenTouchedInstanceCommand}">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ViewModel.LastTouchedInstance}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <ui:ProgressRing
                            IsIndeterminate="True"
                            Width="14" Height="14"
                            Margin="0,2,8,0"
                            VerticalAlignment="Top"
                            Visibility="{Binding ViewModel.IsBusy, Converter={StaticResource BoolToVis}}" />
                        <TextBlock
                            Text="{Binding ViewModel.StatusText}"
                            FontSize="12"
                            TextWrapping="Wrap"
                            MaxWidth="290"
                            Foreground="{StaticResource LauncherMutedForegroundBrush}"
                            Visibility="{Binding ViewModel.StatusText, Converter={StaticResource StringNotEmptyToVis}}" />
                    </StackPanel>
                </StackPanel>

                <!-- Right: draft list + collapsible Modrinth search -->
                <StackPanel Grid.Column="2">
                    <!-- Local filter over the draft + the entry point for adding new mods — mirrors the
                         Content tab: search box filters what's already here, «Найти проекты» finds new. -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox
                            Grid.Column="0"
                            Text="{Binding ViewModel.DraftFilterText, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Поиск среди модов сборки..."
                            Icon="{ui:SymbolIcon Search24}" />
                        <ui:Button
                            Grid.Column="2"
                            Content="Найти проекты"
                            Appearance="Primary"
                            Icon="{ui:SymbolIcon BoxMultiple24}"
                            Command="{Binding ViewModel.ToggleSearchCommand}" />
                    </Grid>

                    <!-- Modrinth search, folded until «Найти проекты» opens it -->
                    <Border Style="{StaticResource LauncherGlassStaticCardStyle}" Padding="18" Margin="0,0,0,14"
                            Visibility="{Binding ViewModel.IsSearchOpen, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Поиск на Modrinth" FontWeight="SemiBold" Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBox
                                    Grid.Column="0"
                                    Text="{Binding ViewModel.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Название мода..."
                                    Icon="{ui:SymbolIcon Search24}" />
                                <ui:Button
                                    Grid.Column="2"
                                    Content="Найти"
                                    Appearance="Primary"
                                    Command="{Binding ViewModel.SearchCommand}" />
                            </Grid>

                            <ui:ProgressRing
                                IsIndeterminate="True"
                                Width="18" Height="18"
                                HorizontalAlignment="Left"
                                Visibility="{Binding ViewModel.IsSearching, Converter={StaticResource BoolToVis}}" />

                            <ItemsControl ItemsSource="{Binding ViewModel.SearchResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="{StaticResource LauncherSurfaceMutedBrush}">
                                                <Grid>
                                                    <ui:SymbolIcon Symbol="BoxMultiple24" FontSize="16" Foreground="{StaticResource LauncherMutedForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <Border CornerRadius="8">
                                                        <Border.Background>
                                                            <ImageBrush ImageSource="{Binding IconUrl}" Stretch="UniformToFill" />
                                                        </Border.Background>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Description}" FontSize="11.5" Foreground="{StaticResource LauncherMutedForegroundBrush}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>

                                            <ui:Button
                                                Grid.Column="3"
                                                Appearance="Primary"
                                                Padding="6"
                                                ToolTip="Добавить в сборку"
                                                Icon="{ui:SymbolIcon Add24}"
                                                Command="{Binding ViewModel.AddModCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Draft mod list -->
                    <Border Style="{StaticResource LauncherGlassStaticCardStyle}" Padding="18">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Margin="0,0,0,10">
                                <Run Text="Моды в сборке" /><Run Text=" (" /><Run Text="{Binding ViewModel.DraftMods.Count, Mode=OneWay}" /><Run Text=")" />
                            </TextBlock>

                            <TextBlock
                                Text="Пока пусто — нажми «Найти проекты» и добавь моды в сборку."
                                FontSize="12"
                                Foreground="{StaticResource LauncherMutedForegroundBrush}"
                                Visibility="{Binding ViewModel.DraftMods.Count, Converter={StaticResource ZeroCountToVis}}" />

                            <ItemsControl ItemsSource="{Binding ViewModel.FilteredDraftMods}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            CornerRadius="10"
                                            Background="{StaticResource LauncherSurfaceBrush}"
                                            BorderBrush="{StaticResource LauncherHairlineBrush}"
                                            BorderThickness="1"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="6" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="{StaticResource LauncherSurfaceMutedBrush}">
                                                    <Grid>
                                                        <ui:SymbolIcon Symbol="BoxMultiple24" FontSize="16" Foreground="{StaticResource LauncherMutedForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        <Border CornerRadius="8">
                                                            <Border.Background>
                                                                <ImageBrush ImageSource="{Binding IconUrl}" Stretch="UniformToFill" />
                                                            </Border.Background>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock
                                                        Text="{Binding Author, StringFormat='от {0}'}"
                                                        FontSize="11"
                                                        Foreground="{StaticResource LauncherMutedForegroundBrush}"
                                                        Visibility="{Binding Author, Converter={StaticResource StringNotEmptyToVis}}" />
                                                    <TextBlock
                                                        Text="Нет версии под выбранную конфигурацию"
                                                        FontSize="11"
                                                        Foreground="#F87171"
                                                        Visibility="{Binding IsIncompatible, Converter={StaticResource BoolToVis}}" />
                                                </StackPanel>

                                                <!-- Exact version pick -->
                                                <StackPanel Grid.Column="3" VerticalAlignment="Center" Orientation="Horizontal">
                                                    <ui:ProgressRing
                                                        IsIndeterminate="True"
                                                        Width="14" Height="14"
                                                        Margin="0,0,8,0"
                                                        Visibility="{Binding IsLoadingVersions, Converter={StaticResource BoolToVis}}" />
                                                    <ComboBox
                                                        Width="150"
                                                        ItemsSource="{Binding AvailableVersions}"
                                                        SelectedItem="{Binding SelectedVersion}"
                                                        DisplayMemberPath="VersionNumber"
                                                        ToolTip="Версия мода"
                                                        Visibility="{Binding IsIncompatible, Converter={StaticResource InverseBoolToVis}}" />
                                                </StackPanel>

                                                <CheckBox
                                                    Grid.Column="5"
                                                    IsChecked="{Binding IsEnabled}"
                                                    ToolTip="Включён в сборке"
                                                    VerticalAlignment="Center" />

                                                <ui:Button
                                                    Grid.Column="7"
                                                    Appearance="Transparent"
                                                    Padding="4"
                                                    ToolTip="Убрать из сборки"
                                                    Icon="{ui:SymbolIcon Delete24}"
                                                    Command="{Binding ViewModel.RemoveModCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock
                                Text="Совет: выключенный мод скачается, но будет отключён — включишь его позже. Конфиги модов правятся во вкладке «Файлы» сборки после первого запуска игры."
                                FontSize="11.5"
                                TextWrapping="Wrap"
                                Foreground="{StaticResource LauncherMutedForegroundBrush}"
                                Margin="0,6,0,0"
                                Visibility="{Binding ViewModel.DraftMods.Count, Converter={StaticResource NonZeroCountToVis}}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>

<Page x:Class="Launcher.App.Views.Pages.ModsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:viewModels="clr-namespace:Launcher.App.ViewModels"
      xmlns:converters="clr-namespace:Launcher.App.Converters"
      xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=viewModels:ModsViewModel}"
      d:DesignWidth="1100" d:DesignHeight="760"
      Title="ModsPage">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis" />
        <converters:NonZeroCountToVisibilityConverter x:Key="NonZeroCountToVis" />

        <Style x:Key="CategoryPillStyle" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Appearance" Value="Secondary" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
    </Page.Resources>

    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        behaviors:ScrollViewerWindowHeightBehavior.Enabled="True">
        <StackPanel Margin="40,32,40,32">
            <TextBlock Text="Поиск проектов" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,20" />

            <!-- Scoped-instance banner — set by "Найти проекты" on an instance's Content tab -->
            <Border
                Style="{StaticResource LauncherGlassCardStyle}"
                Padding="14,12"
                Margin="0,0,0,16"
                Visibility="{Binding ViewModel.HasScopedInstance, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="CubeMultiple24" FontSize="16" Foreground="{StaticResource LauncherAccentSoftBrush}" Margin="0,0,10,0" VerticalAlignment="Center" />
                        <TextBlock VerticalAlignment="Center" FontSize="13">
                            <Run Text="Показаны проекты для сборки" />
                            <Run Text="{Binding ViewModel.ScopedInstance.Name, Mode=OneWay}" FontWeight="SemiBold" />
                            <Run Text="— установка происходит сразу в неё." />
                        </TextBlock>
                    </StackPanel>
                    <ui:Button
                        Grid.Column="1"
                        Content="Показать все проекты"
                        Appearance="Transparent"
                        Command="{Binding ViewModel.ClearScopeCommand}" />
                </Grid>
            </Border>

            <!-- Category tabs -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <ui:Button Content="Всё"
                           Visibility="{Binding ViewModel.HasScopedInstance, Converter={StaticResource InverseBoolToVis}}"
                           Command="{Binding ViewModel.SelectProjectTypeCommand}"
                           CommandParameter="{Binding ViewModel.ProjectTypes[0]}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource CategoryPillStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ViewModel.SelectedProjectType.Key}" Value="">
                                    <Setter Property="Appearance" Value="Primary" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Content="Моды"
                           Command="{Binding ViewModel.SelectProjectTypeCommand}"
                           CommandParameter="{Binding ViewModel.ProjectTypes[1]}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource CategoryPillStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ViewModel.SelectedProjectType.Key}" Value="mod">
                                    <Setter Property="Appearance" Value="Primary" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Content="Наборы ресурсов"
                           Command="{Binding ViewModel.SelectProjectTypeCommand}"
                           CommandParameter="{Binding ViewModel.ProjectTypes[2]}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource CategoryPillStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ViewModel.SelectedProjectType.Key}" Value="resourcepack">
                                    <Setter Property="Appearance" Value="Primary" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Content="Шейдеры"
                           Command="{Binding ViewModel.SelectProjectTypeCommand}"
                           CommandParameter="{Binding ViewModel.ProjectTypes[3]}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource CategoryPillStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ViewModel.SelectedProjectType.Key}" Value="shader">
                                    <Setter Property="Appearance" Value="Primary" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Content="Наборы данных"
                           Command="{Binding ViewModel.SelectProjectTypeCommand}"
                           CommandParameter="{Binding ViewModel.ProjectTypes[4]}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource CategoryPillStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ViewModel.SelectedProjectType.Key}" Value="datapack">
                                    <Setter Property="Appearance" Value="Primary" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Content="Сборки"
                           Visibility="{Binding ViewModel.HasScopedInstance, Converter={StaticResource InverseBoolToVis}}"
                           Command="{Binding ViewModel.SelectProjectTypeCommand}"
                           CommandParameter="{Binding ViewModel.ProjectTypes[5]}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource CategoryPillStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ViewModel.SelectedProjectType.Key}" Value="modpack">
                                    <Setter Property="Appearance" Value="Primary" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Content="Серверы (скоро)"
                           IsEnabled="False"
                           Command="{Binding ViewModel.SelectProjectTypeCommand}"
                           CommandParameter="{Binding ViewModel.ProjectTypes[6]}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource CategoryPillStyle}" />
                    </ui:Button.Style>
                </ui:Button>
            </StackPanel>

            <Border
                Style="{StaticResource LauncherGlassCardStyle}"
                Padding="20"
                Margin="0,0,0,24">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" MinWidth="180" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Поиск на Modrinth" Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    Grid.Column="0"
                                    Text="{Binding ViewModel.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,8,0">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding ViewModel.SearchCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                                <ui:Button
                                    Grid.Column="1"
                                    Content="Найти"
                                    Command="{Binding ViewModel.SearchCommand}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Сортировка" Margin="0,0,0,4" />
                            <ComboBox
                                ItemsSource="{Binding ViewModel.SortOptions}"
                                SelectedItem="{Binding ViewModel.SelectedSortOption}"
                                DisplayMemberPath="Label" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <ui:ProgressRing
                            IsIndeterminate="True"
                            Width="16" Height="16"
                            Margin="0,0,8,0"
                            Visibility="{Binding ViewModel.IsSearching, Converter={StaticResource BoolToVis}}" />
                        <TextBlock
                            Text="{Binding ViewModel.StatusText}"
                            TextWrapping="Wrap"
                            FontSize="12"
                            Foreground="{StaticResource LauncherMutedForegroundBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Search results -->
            <ItemsControl ItemsSource="{Binding ViewModel.SearchResults}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:ModSearchItem}">
                        <Border
                            Style="{StaticResource LauncherGlassCardStyle}"
                            Padding="16"
                            Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="190" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="0"
                                    Width="60" Height="60"
                                    CornerRadius="10"
                                    Background="{StaticResource LauncherSurfaceMutedBrush}"
                                    ClipToBounds="True"
                                    VerticalAlignment="Top">
                                    <Image Source="{Binding Hit.IconUrl}" Stretch="UniformToFill" />
                                </Border>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Hit.Title}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                                        <TextBlock
                                            Text="{Binding Hit.Author, StringFormat='by {0}'}"
                                            FontSize="12"
                                            Foreground="{StaticResource LauncherMutedForegroundBrush}"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock
                                        Text="{Binding Hit.Description}"
                                        FontSize="12"
                                        TextWrapping="Wrap"
                                        MaxHeight="34"
                                        TextTrimming="CharacterEllipsis"
                                        Foreground="{StaticResource LauncherMutedForegroundBrush}"
                                        Margin="0,4,0,0" />
                                    <TextBlock
                                        Text="{Binding Tags}"
                                        FontSize="11"
                                        Foreground="{StaticResource LauncherAccentSoftBrush}"
                                        Margin="0,6,0,0"
                                        Visibility="{Binding Tags, Converter={StaticResource StringNotEmptyToVis}}" />
                                </StackPanel>

                                <StackPanel Grid.Column="4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <ui:Button HorizontalAlignment="Right"
                                               Command="{Binding ViewModel.InstallCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}">
                                        <ui:Button.Style>
                                            <Style TargetType="ui:Button" BasedOn="{StaticResource LauncherGlowButtonStyle}">
                                                <Setter Property="Content" Value="Добавить в сборку" />
                                                <Setter Property="Appearance" Value="Primary" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Hit.ProjectType}" Value="modpack">
                                                        <Setter Property="Content" Value="Установить" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsInstalling}" Value="True">
                                                        <Setter Property="Content" Value="Установка..." />
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                        <Setter Property="Content" Value="Установлен" />
                                                        <Setter Property="Appearance" Value="Secondary" />
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:Button.Style>
                                    </ui:Button>

                                    <TextBlock HorizontalAlignment="Right" FontSize="12" Margin="0,10,0,0"
                                               Foreground="{StaticResource LauncherMutedForegroundBrush}">
                                        <Run Text="⬇" />
                                        <Run Text="{Binding FormattedDownloads, Mode=OneWay}" />
                                        <Run Text="   ♥" />
                                        <Run Text="{Binding FormattedFollows, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock
                                        Text="{Binding FormattedDateModified}"
                                        FontSize="11"
                                        HorizontalAlignment="Right"
                                        Margin="0,4,0,0"
                                        Foreground="{StaticResource LauncherMutedForegroundBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Pagination -->
            <StackPanel
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Margin="0,12,0,0"
                Visibility="{Binding ViewModel.SearchResults.Count, Converter={StaticResource NonZeroCountToVis}}">
                <ui:Button Content="Назад" Appearance="Secondary" Margin="0,0,8,0"
                           Command="{Binding ViewModel.PreviousPageCommand}" />
                <TextBlock
                    VerticalAlignment="Center"
                    Margin="4,0,4,0"
                    Foreground="{StaticResource LauncherMutedForegroundBrush}">
                    <Run Text="Страница" />
                    <Run Text="{Binding ViewModel.CurrentPage, Mode=OneWay}" />
                    <Run Text="из" />
                    <Run Text="{Binding ViewModel.TotalPages, Mode=OneWay}" />
                </TextBlock>
                <ui:Button Content="Вперёд" Appearance="Secondary" Margin="8,0,0,0"
                           Command="{Binding ViewModel.NextPageCommand}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>

<Page x:Class="Launcher.App.Views.Pages.NewsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:viewModels="clr-namespace:Launcher.App.ViewModels"
      xmlns:models="clr-namespace:Launcher.Backend.Models;assembly=Launcher.Backend"
      xmlns:converters="clr-namespace:Launcher.App.Converters"
      xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=viewModels:NewsViewModel}"
      d:DesignWidth="900" d:DesignHeight="600"
      Title="NewsPage"
      Opacity="0"
      RenderTransformOrigin="0.5,0.5">

    <Page.RenderTransform>
        <TranslateTransform Y="14" />
    </Page.RenderTransform>
    <Page.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PageEnterStoryboard}" />
        </EventTrigger>
    </Page.Triggers>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis" />
    </Page.Resources>

    <!-- Root-level height binding (see SupportPage) so the announcements list scrolls within the window. -->
    <Grid Margin="40,32,40,32"
          behaviors:ScrollViewerWindowHeightBehavior.Enabled="True"
          behaviors:ScrollViewerWindowHeightBehavior.Offset="64">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
            <TextBlock Text="Новости" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
            <ui:ProgressRing
                IsIndeterminate="True"
                Width="18" Height="18"
                Margin="12,0,0,0"
                Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <TextBlock
                Text="{Binding ViewModel.StatusText}"
                Foreground="{StaticResource LauncherMutedForegroundBrush}"
                Visibility="{Binding ViewModel.StatusText, Converter={StaticResource StringNotEmptyToVis}}" />

            <TextBlock
                Text="Пока нет объявлений."
                Foreground="{StaticResource LauncherMutedForegroundBrush}"
                HorizontalAlignment="Left" VerticalAlignment="Top">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ViewModel.Announcements.Count}" Value="0" />
                                    <Condition Binding="{Binding ViewModel.IsLoading}" Value="False" />
                                    <!-- An error message replaces (not overlaps) the empty-state text. -->
                                    <Condition Binding="{Binding ViewModel.StatusText}" Value="" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ViewModel.Announcements}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel MaxWidth="700" HorizontalAlignment="Left" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:Announcement}">
                            <Border
                                CornerRadius="12"
                                Background="{StaticResource LauncherSurfaceBrush}"
                                BorderBrush="{StaticResource LauncherHairlineBrush}"
                                BorderThickness="1"
                                Padding="20"
                                Margin="0,0,0,12">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <ui:SymbolIcon
                                            Symbol="Pin24"
                                            Foreground="{StaticResource LauncherAccentSoftBrush}"
                                            Margin="0,0,6,0"
                                            Visibility="{Binding Pinned, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="16" />
                                    </StackPanel>
                                    <TextBlock
                                        Text="{Binding Body}"
                                        TextWrapping="Wrap"
                                        Margin="0,0,0,10" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            Text="{Binding Author}"
                                            FontSize="12"
                                            Foreground="{StaticResource LauncherMutedForegroundBrush}" />
                                        <TextBlock
                                            Text=" · "
                                            FontSize="12"
                                            Foreground="{StaticResource LauncherMutedForegroundBrush}" />
                                        <TextBlock
                                            Text="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                            FontSize="12"
                                            Foreground="{StaticResource LauncherMutedForegroundBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>

<Page x:Class="Launcher.App.Views.Pages.SupportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:viewModels="clr-namespace:Launcher.App.ViewModels"
      xmlns:models="clr-namespace:Launcher.Backend.Models;assembly=Launcher.Backend"
      xmlns:converters="clr-namespace:Launcher.App.Converters"
      xmlns:behaviors="clr-namespace:Launcher.App.Behaviors"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=viewModels:SupportViewModel}"
      d:DesignWidth="1000" d:DesignHeight="600"
      Title="SupportPage"
      Opacity="0"
      RenderTransformOrigin="0.5,0.5">

    <Page.RenderTransform>
        <TranslateTransform Y="14" />
    </Page.RenderTransform>
    <Page.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PageEnterStoryboard}" />
        </EventTrigger>
    </Page.Triggers>

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis" />
    </Page.Resources>

    <!--
        The page is Frame-hosted, so star rows never get a bounded height on their own (see
        ScrollViewerWindowHeightBehavior). Bind the ROOT grid's height — with Offset covering the
        32+32 vertical margins — so the thread list scrolls and the "Новое обращение" panel stays
        pinned at the bottom instead of being pushed off-screen.
    -->
    <Grid Margin="40,32,40,32"
          behaviors:ScrollViewerWindowHeightBehavior.Enabled="True"
          behaviors:ScrollViewerWindowHeightBehavior.Offset="64">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="{StaticResource LauncherForegroundBrush}">
                <TextBlock.Style>
                    <!--
                        BasedOn is the primary path — it inherits the app-wide white-text style from
                        Brushes.xaml. The Foreground set directly above is the fallback: a local value
                        always wins even if BasedOn ever fails to resolve, so the title can't go back
                        to WPF's default black TextBlock foreground either way.
                    -->
                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                        <Setter Property="Text" Value="Поддержка" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ViewModel.IsHistoryView}" Value="True">
                                <Setter Property="Text" Value="История тем" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <ui:Button Grid.Column="1" Command="{Binding ViewModel.ToggleHistoryViewCommand}">
                <ui:Button.Style>
                    <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                        <Setter Property="Content" Value="История тем" />
                        <Setter Property="Icon" Value="{ui:SymbolIcon History24}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ViewModel.IsHistoryView}" Value="True">
                                <Setter Property="Content" Value="Назад" />
                                <Setter Property="Icon" Value="{ui:SymbolIcon ArrowLeft24}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:Button.Style>
            </ui:Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: thread list + new thread -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ListBox
                    Grid.Row="0"
                    ItemsSource="{Binding ViewModel.Threads}"
                    SelectedItem="{Binding ViewModel.SelectedThread}"
                    Background="Transparent"
                    BorderThickness="0"
                    ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border
                                            x:Name="ItemBorder"
                                            CornerRadius="10"
                                            Padding="12,10"
                                            Background="{StaticResource LauncherSurfaceBrush}"
                                            Cursor="Hand">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource LauncherAccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:SupportThread}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Subject}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="11" Foreground="{StaticResource LauncherMutedForegroundBrush}" Margin="0,2,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Открыто" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="closed">
                                                        <Setter Property="Text" Value="Завершено" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <ui:Button
                                    Grid.Column="1"
                                    Appearance="Transparent"
                                    Padding="4"
                                    ToolTip="Удалить обращение"
                                    Icon="{ui:SymbolIcon Delete24}"
                                    Command="{Binding ViewModel.DeleteThreadCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border
                    Grid.Row="1"
                    CornerRadius="12"
                    Background="{StaticResource LauncherSurfaceBrush}"
                    BorderBrush="{StaticResource LauncherHairlineBrush}"
                    BorderThickness="1"
                    Padding="14"
                    Margin="0,8,0,0"
                    Visibility="{Binding ViewModel.IsHistoryView, Converter={StaticResource InverseBoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Новое обращение" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBox
                            Text="{Binding ViewModel.NewThreadSubject, UpdateSourceTrigger=PropertyChanged}"
                            Margin="0,0,0,8" />
                        <ui:Button
                            Content="Создать"
                            Appearance="Primary"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Command="{Binding ViewModel.CreateThreadCommand}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Right: chat -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Selected thread's subject + Завершить диалог / delete — hidden until a thread is picked. -->
                <Grid Grid.Row="0" Margin="0,0,0,12" Visibility="{Binding ViewModel.HasSelectedThread, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Text="{Binding ViewModel.SelectedThread.Subject}"
                        FontWeight="SemiBold"
                        FontSize="15"
                        VerticalAlignment="Center"
                        TextTrimming="CharacterEllipsis" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ui:Button
                            Content="Завершить диалог"
                            Appearance="Secondary"
                            Margin="0,0,8,0"
                            Command="{Binding ViewModel.CloseThreadCommand}"
                            Visibility="{Binding ViewModel.CanCloseSelectedThread, Converter={StaticResource BoolToVis}}" />
                        <ui:Button
                            Appearance="Transparent"
                            Padding="6"
                            ToolTip="Удалить обращение"
                            Icon="{ui:SymbolIcon Delete24}"
                            Command="{Binding ViewModel.DeleteThreadCommand}"
                            CommandParameter="{Binding ViewModel.SelectedThread}" />
                    </StackPanel>
                </Grid>

                <TextBlock
                    Grid.Row="1"
                    Text="Выберите обращение слева или создайте новое."
                    Foreground="{StaticResource LauncherMutedForegroundBrush}"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Visibility="{Binding ViewModel.HasSelectedThread, Converter={StaticResource InverseBoolToVis}}" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding ViewModel.HasSelectedThread, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding ViewModel.Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SupportMessage}">
                                <Border
                                    CornerRadius="10"
                                    Padding="12,8"
                                    Margin="0,0,0,8"
                                    MaxWidth="480">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource LauncherSurfaceBrush}" />
                                            <Setter Property="HorizontalAlignment" Value="Left" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Sender}" Value="user">
                                                    <Setter Property="Background" Value="{StaticResource LauncherAccentBrush}" />
                                                    <Setter Property="HorizontalAlignment" Value="Right" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Body}" TextWrapping="Wrap" />
                                        <TextBlock
                                            Text="{Binding CreatedAt, StringFormat={}{0:dd.MM HH:mm}}"
                                            FontSize="10"
                                            Opacity="0.7"
                                            Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid Grid.Row="2" Margin="0,12,0,0" Visibility="{Binding ViewModel.CanCloseSelectedThread, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        Grid.Column="0"
                        Text="{Binding ViewModel.MessageText, UpdateSourceTrigger=PropertyChanged}"
                        Margin="0,0,10,0" />
                    <ui:Button
                        Grid.Column="1"
                        Content="Отправить"
                        Appearance="Primary"
                        Command="{Binding ViewModel.SendMessageCommand}" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
